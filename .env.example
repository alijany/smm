# Platform Environment Configuration
# Copy this file to .env and update with your values

###################
# Core API Configuration
###################
NODE_ENV=production
PORT=4000
PROJECT_NAME=App
DOMAIN=app.ir
APP_VERSION=1.0.0

# Admin bootstrap (optional)
# If set, core-api will ensure a user with this phone exists and has the `admin` role on startup.
# Use E.164 format if possible (e.g. +989123456789).
ADMIN_PHONE=''

###################
# Database Configuration
###################
POSTGRES_USER='postgres'
POSTGRES_PASSWORD='pass123'
POSTGRES_DB='app'
POSTGRES_PORT='5432'
DB_HOST='db'

###################
# Redis Configuration
###################
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

###################
# JWT Configuration
###################
JWT_SECRET=your_secure_jwt_secret_here_minimum_32_characters
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your_secure_jwt_refresh_secret_here_minimum_32_characters
JWT_REFRESH_EXPIRATION=30d

###################
# OTP Configuration
###################
OTP_EXPIRATION=300
OTP_LENGTH=4

###################
# SMS Configuration
###################
ASANAK_API='https://sms.asanak.ir/webservice/v2rest/sendsms'
ASANAK_API_USER='asanak_user_name'
ASANAK_API_PASS='asanak_api_password'
ASANAK_API_SOURCE='asanak_phone_password'

###################
# S3 Storage Configuration (RustFS)
###################
S3_ENDPOINT=http://rustfs:9000
S3_ACCESS_KEY=your_rustfs_access_key
S3_SECRET_KEY=your_rustfs_secret_key
S3_BUCKET_NAME='app-dev'
S3_BUCKET=app
S3_REGION=us-east-1

###################
# Payment Gateway Configuration
###################

# Zibal Payment Gateway
ZIBAL_MERCHANT=your_zibal_merchant_id
ZIBAL_CALLBACK_URL=http://app.ir/api/v1/payment/zibal-callback
ZIBAL_FRONTEND_CALLBACK_URL=http://app.ir/dashboard/transaction/zibal

###################
# PWA Frontend Configuration
###################
NEXT_PUBLIC_API_URL=https://app.ir/api/v1

# Microsoft Clarity Analytics
NEXT_PUBLIC_CLARITY_PROJECT_ID=clarity_project_id
