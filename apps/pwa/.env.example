# Environment Configuration for the PWA

# Backend API Configuration
# Relative path — works behind the nginx reverse proxy in devcontainer/Codespaces.
# For local development without nginx, set to http://localhost:4000/api/v1
NEXT_PUBLIC_API_URL=/api/v1

# Server-side API base URL (used by server components and server actions)
# Must be the full internal URL reachable from the Next.js server process
API_BASE_URL=http://localhost:4000/api/v1

# Development Configuration
NODE_ENV=development

# Production Configuration (uncomment and set for production)
# NODE_ENV=production

# Microsoft Clarity Analytics Configuration
# Project ID from https://clarity.microsoft.com/
NEXT_PUBLIC_CLARITY_PROJECT_ID=clarity_project_id
